# Frontend site URL (used for payment success/cancel redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional default checkout currency
CHECKOUT_CURRENCY=CZK

# Packeta / Zasilkovna widget (pickup point map)
NEXT_PUBLIC_PACKETA_API_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
INTERNAL_API_SECRET=your_shared_internal_secret

# Global Payments (GP eCommerce HPP)
GP_ENVIRONMENT=TEST
GP_MERCHANT_ID=your_merchant_id
GP_ACCOUNT_ID=internet
GP_SHARED_SECRET=your_shared_secret
GP_CHANNEL=
GP_HPP_URL=https://pay.sandbox.realexpayments.com/pay
GP_HPP_LANGUAGE=EN
GP_HPP_BUTTON_TEXT=Pay now
# Optional explicit callback endpoint. If empty, app builds it automatically.
# GP_HPP_RESPONSE_URL=http://localhost:3000/api/payments/global-payments/response
